 80)",[1438,1438],[1444,1450],"    }))",[1452,1452],[1476,1509],"  const canvas = canvasRef.current",[1510,1534],"      if (!canvas) return",[1535,1575],"      const ctx = canvas.getContext('2d')",[1576,1597],"      if (!ctx) return",[1599,1629],"      let W = window.innerWidth",[1630,1661],"      let H = window.innerHeight",[1662,1690],"      const FLAKE_COUNT = 180",[1691,1730],"      const flakes: FlakeParticle[] = []",[1731,1775],"      const trailFlakes: TrailParticle[] = []",[1776,1811],"      const accum = accumRef.current",[1813,1817],[1846,1889],"        W = canvas.width = window.innerWidth",[1896,1935],"  H = canvas.height = window.innerHeight",[1936,1942],[1943,1989],"      window.addEventListener('resize', resize)",[1990,2003],"      resize()",[2009,2009],[2059,2144],"  x: number\n        y: number\n        r: number\n        vx: number\n        vy: number\n        life: number\n        decay: number",[2145,2145],[2187,2235],"          this.x = x + (Math.random() - 0.5) * 12",[2236,2284],"          this.y = y + (Math.random() - 0.5) * 12",[2285,2326],"          this.r = Math.random() * 2.5 + 1",[2335,2373],"  this.vx = (Math.random() - 0.5) * 1.5",[2374,2420],"          this.vy = (Math.random() - 0.5) * 1.5",[2421,2443],"          this.life = 1",[2444,2495],"          this.decay = Math.random() * 0.015 + 0.015",[2496,2496],[2504,2504],[2535,2553],"  this.x += this.vx",[2554,2580],"          this.y += this.vy",[2581,2605],"          this.vy += 0.04",[2606,2638],"          this.life -= this.decay",[2639,2639],[2647,2653],"        ",[2676,2692],"  if (!ctx) return",[2693,2717],"          ctx.beginPath()",[2726,2774],"  ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2)",[2775,2838],"          ctx.fillStyle = `rgba(255,255,255,${this.life * 0.8})`",[2839,2858],"          ctx.fill()",[2859,2859],[2871,2871],[2874,2874],[2923,3039],"  x!: number\n        y!: number\n        r!: number\n        speed!: number\n        wind!: number\n        swing!: number\n        phase!: number\n        opacity!: number",[3040,3079],"        constructor() {\n          this.reset(true)\n       ",[3088,3088],[3117,3152],"          this.x = Math.random() * W",[3153,3206],"          this.y = init ? Math.random() * H * -1 : -10",[3215,3250],"  this.r = Math.random() * 2.5 + 0.8",[3251,3260],[3311,3416],"  this.speed =\n              Math.random() * (10 + burstIntensityRef.current * 15) +\n              (5 + burstIntensityRef.current * 5)",[3417,3501],"            this.wind = (Math.random() - 0.5) * (15 + burstIntensityRef.current * 25)",[3502,3502],[3529,3568],"  this.speed = Math.random() * 1.2 + 0.4",[3569,3617],"            this.wind = Math.random() * 0.6 - 0.3",[3618,3618],[3636,3678],"  this.swing = Math.random() * 0.02 + 0.005",[3679,3728],"          this.phase = Math.random() * Math.PI * 2",[3729,3778],"          this.opacity = Math.random() * 0.6 + 0.3",[3779,3779],[3787,3787],[3810,3843],"          this.phase += this.swing",[3844,3901],"          this.x += Math.sin(this.phase) * 0.8 + this.wind",[3902,3931],"          this.y += this.speed",[3932,3941],[3984,3994],[4018,4065],"              this.tryAccumulate(this.x, H - 60)",[4078,4096],"  this.reset(false)",[4097,4116],"              return",[4117,4117],[4129,4168],"            const targets = accumTargets",[4179,4179],[4221,4252],"  if (\n                this.x >= rect.left - 10 &&\n               ",[4323,4346],"\n                this.y <= rect.top + 3\n              ",[4350,4401],"                this.tryAccumulate(this.x, rect.top)",[4416,4434],[4435,4456],"                return",[4457,4457],[4481,4481],[4483,4483],[4493,4575],"          if (this.x < -40 || this.x > W + 40 || this.y > H + 20) this.reset(false)",[4576,4582],[4584,4584],[4642,4678],"  if (snowAccumMode === 'off') return",[4679,4755],"          if (snowAccumMode === 'normal' && accum.length > 500) accum.shift()",[4756,4835],"          if (snowAccumMode === 'extreme' && accum.length > 10000) accum.shift()",[4836,4909],"\n          const chance = snowAccumMode === 'extreme' ? 0.85 : 0.3",[4910,4974],"          if (Math.random() < chance) {\n            let stackY = y",[4975,5034],"            const searchX = x + (Math.random() - 0.5) * 16\n  ",[5121,5121],[5214,5282],"  stackY = Math.min(stackY, accum[i].y - (Math.random() * 1.5 + 0.8))",[5295,5295],[5297,5297],[5309,5309],[5332,5366],"              x: searchX,\n              y: stackY,\n             ",[5377,5377],[5430,5442],[5490,5490],[5508,5511],"  })",[5512,5512],[5528,5528],[5530,5530],[5559,5575],[5584,5600],"  ctx.beginPath()",[5601,5657],"          ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2)",[5658,5718],"          ctx.fillStyle = `rgba(255,255,255,${this.opacity})`",[5719,5738],[5739,5739],[5747,5747],[5758,5791],"  let accumTargets: DOMRect[] = []",[5792,5816],"      let targetTimer = 0",[5818,5818],[5864,5892],"  const rects: DOMRect[] = []",[5893,5954],"        const sb = document.getElementById('searchBarWrapper')",[5955,6008],"        if (sb) rects.push(sb.getBoundingClientRect())",[6009,6016],[6050,6143],"  document\n            .querySelectorAll('.nav-card')\n            .forEach((el) => rects.push(el.getBoundingClientRect()))",[6152,6246],"  document\n            .querySelectorAll('.card-link')\n            .forEach((el) => rects.push(el.getBoundingClientRect()))",[6253,6253],[6255,6282],"        accumTargets = rects",[6283,6289],[6295,6358],"  for (let i = 0; i < FLAKE_COUNT; i++) flakes.push(new Flake())",[6360,6364],[6421,6421],[6438,6524],"          for (let i = 0; i < 2; i++) trailFlakes.push(new TrailFlake(e.clientX, e.clientY))",[6525,6531],[6533,6539],[6540,6600],"      document.addEventListener('mousemove', handleMouseMove)",[6602,6606],[6659,6702],"  const icon = document.createElement('div')",[6709,6744],"  icon.className = 'click-snowflake'",[6745,6786],"        icon.style.left = e.clientX + 'px'",[6787,6827],"        icon.style.top = e.clientY + 'px'",[6828,6866],"        document.body.appendChild(icon)",[6873,6910],"  setTimeout(() => icon.remove(), 900)",[6912,6955],"        const cx = e.clientX,\n          cy = e.clientY",[6956,6985],"        const clearRadius = 60",[6986,6986],[7038,7095],"          const dx = accum[i].x - cx,\n            dy = accum[i].y - cy",[7096,7096],[7167,7186],"  accum.splice(i, 1)",[7187,7195],"          ",[7197,7197],[7205,7211],[7212,7264],"      document.addEventListener('click', handleClick)",[7266,7266],[7297,7329],"        ctx.clearRect(0, 0, W, H)",[7330,7350],"        targetTimer++",[7351,7401],"        if (targetTimer % 30 === 0) updateTargets()\n",[7404,7470],"      if (burstTimerRef.current > 0) burstTimerRef.current--",[7472,7478],[7503,7550],"  flakes.forEach((f) => {\n            f.update()\n            f.draw()\n          })",[7551,7557],[7566,7604],"          flakes.forEach((f) => f.draw())",[7605,7611],[7614,7614],[7672,7705],"          const t = trailFlakes[i]",[7706,7725],"          t.update()",[7726,7776],"          if (t.life <= 0) trailFlakes.splice(i, 1)",[7777,7799],"          else t.draw()",[7800,7806],[7809,7880],"        const meltRate = snowAccumMode === 'extreme' ? 0.000015 : 0.0008",[7887,7887],[7941,7960],"  const a = accum[i]",[7961,7985],[7994,8033],"  ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2)",[8034,8100],"          ctx.fillStyle = `rgba(255,255,255,${a.opacity * a.life})`",[8101,8120],[8121,8148],"          a.life -= meltRate",[8149,8193],"          if (a.life <= 0) accum.splice(i, 1)",[8194,8200],[8203,8255],"        animRef.current = requestAnimationFrame(draw)",[8256,8262],[8267,8274],"  draw()",[8276,8276],[8295,8346],"        window.removeEventListener('resize', resize)",[8353,8412],"  document.removeEventListener('mousemove', handleMouseMove)",[8413,8470],"        document.removeEventListener('click', handleClick)",[8471,8536],"        if (animRef.current) cancelAnimationFrame(animRef.current)",[8537,8543],[8544,8589],"    }, [isFocusMode, snowAccumMode, isPaused])",[8591,8651],"    return 